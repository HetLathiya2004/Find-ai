[Unit]
Description=Uptime Kuma — monitor deployed services
After=docker.service
Requires=docker.service

[Service]
Type=oneshot
RemainAfterExit=yes
ExecStart=/usr/bin/docker start uptime-kuma
ExecStartPre=-/usr/bin/docker run -d --name uptime-kuma --restart=always -p 3001:3001 -v uptime-kuma:/app/data louislam/uptime-kuma:1
ExecStop=/usr/bin/docker stop uptime-kuma

[Install]
WantedBy=multi-user.target
