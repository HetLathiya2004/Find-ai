[Unit]
Description=llama.cpp OTEL Gateway (public :8080 → localhost:18080)
After=network-online.target llama-server.service
Wants=network-online.target
Requires=llama-server.service

[Service]
Type=simple
WorkingDirectory=/home/phinex/server/llm-gateway
Environment=PATH=/home/phinex/server/llm-gateway/.venv/bin:/home/phinex/.local/bin:/usr/bin:/bin
Environment=HOME=/home/phinex
Environment=LLAMA_UPSTREAM=http://127.0.0.1:18080
Environment=OTEL_ENABLED=true
Environment=OTEL_SERVICE_NAME=llama-server
Environment=OTEL_EXPORTER_OTLP_ENDPOINT=http://127.0.0.1:4317
Environment=OTEL_EXPORTER_OTLP_PROTOCOL=grpc
ExecStart=/home/phinex/server/llm-gateway/.venv/bin/uvicorn main:app --host 0.0.0.0 --port 8080
Restart=always
RestartSec=5
StandardOutput=journal
StandardError=journal
SyslogIdentifier=llama-gateway

[Install]
WantedBy=default.target
